#!/usr/bin/env bash
# Anonimiza caras en imágenes o video seleccionados en Nautilus.
# Acepta archivos individuales, un directorio de imágenes, o un video único.

export PATH="/home/linuxbrew/.linuxbrew/bin:/home/tcabrera/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

SCRIPT="$HOME/scripts/pixelize.py"
VIDEO_SCRIPT="$HOME/scripts/video_pixelize.py"
PYTHON="/home/tcabrera/.local/share/pipx/venvs/deface/bin/python3"

IMAGE_EXTS="jpg|jpeg|png|webp"
VIDEO_EXTS="mp4|mkv|avi|mov|webm|m4v"

mapfile -t _raw <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${_raw[@]}"; do [[ -n "$f" ]] && files+=("$f"); done

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    zenity --error --text="No files received." --title="Pixelize"
    exit 1
fi

get_unique_dir() {
    local base="$1"
    local dir="$base"
    local n=2
    while [[ -d "$dir" ]]; do dir="${base}_${n}"; n=$((n+1)); done
    echo "$dir"
}

# ── Directory mode ────────────────────────────────────────────────────────────
if [ -d "${files[0]}" ]; then
    dir="${files[0]}"
    mapfile -t imgs < <(find "$dir" -maxdepth 1 -type f | grep -iE "\.(${IMAGE_EXTS})$" | sort)

    if [ ${#imgs[@]} -eq 0 ]; then
        zenity --error --text="No images found in the directory." --title="Pixelize"
        exit 1
    fi

    outdir=$(get_unique_dir "$(dirname "$dir")/$(basename "$dir")_gaussian")
    mkdir -p "$outdir"

    PID_FILE=$(mktemp)
    (
        total=${#imgs[@]}
        i=0
        for img in "${imgs[@]}"; do
            i=$((i + 1))
            name=$(basename "$img")
            pct=$(( i * 100 / total ))
            echo "$pct"
            echo "# ($i/$total) $name"
            "$PYTHON" "$SCRIPT" "$img" --flat --output-dir "$outdir" >/dev/null 2>>/tmp/pixelize.log &
            echo $! > "$PID_FILE"
            wait
        done
        echo "100"
        echo "# Done"
    ) | zenity --progress \
        --title="Pixelizing directory..." \
        --text="Starting..." \
        --percentage=0 --auto-close --width=380

    EXIT_CODE=${PIPESTATUS[1]}
    if [[ $EXIT_CODE -ne 0 ]]; then
        WPID=$(cat "$PID_FILE" 2>/dev/null)
        [[ -n "$WPID" ]] && kill "$WPID" 2>/dev/null
        rm -f "$PID_FILE"; exit 0
    fi
    rm -f "$PID_FILE"

    pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null
    action=$(notify-send --wait --action="open=Open folder" \
        "Pixelize done" "${#imgs[@]} image(s) → $(basename "$outdir")" --icon=emblem-photos)
    [[ "$action" == "open" ]] && nautilus "$outdir" 2>/dev/null &
    exit 0
fi

# ── Video mode (single video file) ────────────────────────────────────────────
ext="${files[0]##*.}"
if [ ${#files[@]} -eq 1 ] && echo "${ext,,}" | grep -qE "^($VIDEO_EXTS)$"; then
    src="${files[0]}"
    duration_total=$(ffprobe -v error -show_entries format=duration -of default=nw=1:nk=1 "$src" 2>/dev/null | awk '{printf "%.1f", $1}')
    hms=$(awk -v s="$duration_total" 'BEGIN{h=int(s/3600); m=int((s%3600)/60); sec=int(s%60); printf "%02d:%02d:%02d", h, m, sec}')

    values=$(zenity --forms \
        --title="Pixelize video" \
        --text="File: $(basename "$src")\nDuration: ${duration_total}s (${hms})\n\nRange optional. Start/End accept seconds or HH:MM:SS; in 'End' without ':' it's interpreted as duration in seconds.\n" \
        --add-entry="Start (empty = 0)" \
        --add-entry="End — HH:MM:SS (timestamp) or seconds (duration)" \
        --add-combo="Model" --combo-values="SCRFD (balance · default)|RetinaFace-R34 (max precision · ~3× slower)|CenterFace (faster)" \
        --add-combo="Fill gaps" --combo-values="Yes|No" \
        --add-entry="Block %% of face width (30)" \
        --add-entry="Detection threshold (0.2)" \
        --separator="|" \
        --width=560 --height=516)

    [ -z "$values" ] && exit 0

    IFS='|' read -r V_START V_END V_MODEL V_FILL V_BLOCK V_THRESH <<< "$values"
    args=()
    [[ -n "$V_START" ]] && args+=(--start "$V_START")
    if [[ -n "$V_END" ]]; then
        if [[ "$V_END" == *:* ]]; then
            args+=(--to "$V_END")
        else
            args+=(--duration "$V_END")
        fi
    fi
    case "$V_MODEL" in
        "CenterFace (faster)") args+=(--model centerface) ;;
        "RetinaFace-R34 (max precision · ~3× slower)") args+=(--model retinaface) ;;
        *) args+=(--model scrfd) ;;
    esac
    [[ "$V_FILL" == "No" ]] && args+=(--no-fill-gaps)
    [[ -n "$V_BLOCK" ]]  && args+=(--block-pct "$V_BLOCK")
    [[ -n "$V_THRESH" ]] && args+=(--threshold "$V_THRESH")

    parent=$(dirname "$src")
    LOG=/tmp/video_pixelize.log
    : > "$LOG"

    (
        echo "5"
        echo "# Extracting frames..."
        "$PYTHON" "$VIDEO_SCRIPT" "$src" "${args[@]}" >>"$LOG" 2>&1 &
        PID=$!
        while kill -0 "$PID" 2>/dev/null; do
            if grep -q "Re-encoding" "$LOG"; then
                echo "85"; echo "# Re-encoding video..."
            elif grep -q "Applying mosaic" "$LOG"; then
                echo "65"; echo "# Applying mosaic..."
            elif grep -q "Detecting faces" "$LOG"; then
                last=$(grep -oE "[0-9]+/[0-9]+ analyzed" "$LOG" | tail -1)
                echo "30"; echo "# Detecting faces ${last}"
            fi
            sleep 0.5
        done
        wait "$PID"
        rc=$?
        echo "100"
        [[ $rc -eq 0 ]] && echo "# Done" || echo "# Error (see $LOG)"
        exit $rc
    ) | zenity --progress \
        --title="Pixelize video..." \
        --text="Starting..." \
        --percentage=0 --auto-close --width=400

    EXIT=${PIPESTATUS[0]}
    pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null

    out=$(grep -oE '^✓ /[^ ]+' "$LOG" | tail -1 | sed 's/^✓ //')

    if [[ $EXIT -ne 0 || -z "$out" || ! -f "$out" ]]; then
        err=$(tail -8 "$LOG")
        zenity --error --title="Pixelize video — failed" --text="$err" --width=520
        exit 1
    fi

    size_mb=$(awk -v b="$(stat -c%s "$out")" 'BEGIN{printf "%.1f", b/1048576}')
    action=$(notify-send --wait --action="open=Open folder" \
        "Video pixelated" "$(basename "$out") — ${size_mb} MB" --icon=emblem-videos)
    [[ "$action" == "open" ]] && nautilus "$parent" 2>/dev/null &
    exit 0
fi

# ── Individual image files mode ───────────────────────────────────────────────
if ! echo "${ext,,}" | grep -qE "^($IMAGE_EXTS)$"; then
    zenity --error --text="Unsupported format. Images: ${IMAGE_EXTS//|/, }  ·  Video (single): ${VIDEO_EXTS//|/, }  ·  or a directory." --title="Pixelize"
    exit 1
fi

mode=$(zenity --list \
    --title="Pixelize images" \
    --text="Pick profile for ${#files[@]} file(s):" \
    --radiolist \
    --column="" --column="Mode" --column="Description" \
    --print-column=2 \
    TRUE  "quick" "Essential variants — fast" \
    FALSE "full"  "All anonymization variants" \
    --width=560 --height=360)

[ -z "$mode" ] && exit 0

suffix="_quick"; [[ "$mode" == "full" ]] && suffix="_anonymized"

declare -a output_dirs=()
for file in "${files[@]}"; do
    parent=$(dirname "$file")
    stem=$(basename "${file%.*}")
    output_dirs+=("$(get_unique_dir "$parent/${stem}${suffix}")")
done

(
    total=${#files[@]}
    i=0
    for file in "${files[@]}"; do
        i=$((i + 1))
        name=$(basename "$file")
        pct=$(( i * 100 / total ))
        echo "$pct"
        echo "# ($i/$total) $name"
        "$PYTHON" "$SCRIPT" "$file" --profile "$mode" --output-dir "${output_dirs[$((i-1))]}" >/dev/null 2>>/tmp/pixelize.log
    done
    echo "100"
    echo "# Done"
) | zenity --progress \
    --title="Pixelizing..." \
    --text="Starting..." \
    --percentage=0 --auto-close --width=380

pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null

no_faces=0
for d in "${output_dirs[@]}"; do [[ ! -d "$d" ]] && no_faces=$((no_faces + 1)); done
ok=$(( ${#files[@]} - no_faces ))

if [[ $no_faces -gt 0 && $ok -eq 0 ]]; then
    notify-send "Pixelize — no faces" "No faces detected in any image" --icon=dialog-warning
elif [[ $no_faces -gt 0 ]]; then
    action=$(notify-send --wait --action="open=Open folder" \
        "Pixelize done (with warnings)" "$ok processed, $no_faces with no faces" --icon=emblem-photos)
    [[ "$action" == "open" ]] && nautilus "${output_dirs[-1]}" 2>/dev/null &
else
    action=$(notify-send --wait --action="open=Open folder" \
        "Pixelize done" "${#files[@]} image(s) → $(basename "${output_dirs[-1]}")" --icon=emblem-photos)
    [[ "$action" == "open" ]] && nautilus "${output_dirs[-1]}" 2>/dev/null &
fi
