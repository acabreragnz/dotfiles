#!/usr/bin/env bash
# Rota un video seleccionado en Nautilus usando ffmpeg (re-encoding).

export PATH="/home/linuxbrew/.linuxbrew/bin:/home/tcabrera/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

VIDEO_EXTS="mp4|mkv|avi|mov|webm|m4v|flv|wmv"

mapfile -t _raw <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${_raw[@]}"; do [[ -n "$f" ]] && files+=("$f"); done

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    zenity --error --text="No se recibieron archivos." --title="Rotar video"
    exit 1
fi

ext="${files[0]##*.}"
if ! echo "${ext,,}" | grep -qE "^($VIDEO_EXTS)$"; then
    zenity --error --text="Este script es solo para videos." --title="Rotar video"
    exit 1
fi

get_unique_dir() {
    local base="$1" dir="$base" n=2
    while [[ -d "$dir" ]]; do dir="${base}_${n}"; n=$((n+1)); done
    echo "$dir"
}

angulo=$(zenity --list \
    --title="Rotar video" \
    --text="Elegí la rotación para ${#files[@]} video(s):" \
    --radiolist \
    --column="" --column="Ángulo" --column="Descripción" \
    --print-column=2 \
    TRUE  "180"  "180° — grabado al revés (más común)" \
    FALSE "90"   "90° — sentido horario" \
    FALSE "270"  "270° — sentido antihorario" \
    --width=480 --height=300)

[ -z "$angulo" ] && exit 0

case "$angulo" in
    90)  vf="transpose=1" ;;
    180) vf="hflip,vflip" ;;
    270) vf="transpose=2" ;;
esac

declare -a output_dirs=()
declare -a output_files=()
for file in "${files[@]}"; do
    dir=$(dirname "$file")
    stem=$(basename "${file%.*}")
    outdir=$(get_unique_dir "$dir/${stem}_rotado")
    output_dirs+=("$outdir")
    output_files+=("$outdir/${stem}_rotado.mp4")
done

PID_FILE=$(mktemp)

(
    total=${#files[@]}
    i=0
    for file in "${files[@]}"; do
        i=$((i + 1))
        name=$(basename "$file")
        outdir="${output_dirs[$((i-1))]}"
        out="${output_files[$((i-1))]}"
        pct=$(( i * 100 / total ))
        echo "$pct"
        echo "# ($i/$total) $name"

        mkdir -p "$outdir"
        ffmpeg -y -i "$file" -vf "$vf" -c:v libx264 -crf 18 -preset fast \
               -c:a copy -map_metadata 0 -metadata:s:v:0 rotate=0 "$out" 2>/dev/null &
        echo $! > "$PID_FILE"
        wait
        touch -r "$file" "$out" 2>/dev/null
    done
    echo "100"
    echo "# Listo"
) | zenity --progress \
    --title="Rotando video..." \
    --text="Iniciando..." \
    --percentage=0 --auto-close --width=380

EXIT_CODE=${PIPESTATUS[1]}
if [[ $EXIT_CODE -ne 0 ]]; then
    WPID=$(cat "$PID_FILE" 2>/dev/null)
    [[ -n "$WPID" ]] && kill "$WPID" 2>/dev/null
    rm -f "$PID_FILE"; exit 0
fi
rm -f "$PID_FILE"

pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null

failed=0
for f in "${output_files[@]}"; do [[ ! -f "$f" ]] && failed=$((failed + 1)); done
ok=$(( ${#files[@]} - failed ))

if [[ $failed -gt 0 && $ok -eq 0 ]]; then
    notify-send "Rotar video — error" "No se pudo rotar ningún video" --icon=dialog-error
elif [[ $failed -gt 0 ]]; then
    action=$(notify-send --wait --action="open=Abrir carpeta" \
        "Video rotado (con errores)" "$ok rotado(s), $failed fallido(s)" --icon=emblem-videos)
    [[ "$action" == "open" ]] && nautilus "$(dirname "${output_files[0]}")" 2>/dev/null &
else
    action=$(notify-send --wait --action="open=Abrir carpeta" \
        "Video rotado" "$ok video(s) — ${angulo}°" --icon=emblem-videos)
    [[ "$action" == "open" ]] && nautilus "$(dirname "${output_files[0]}")" 2>/dev/null &
fi
