#!/usr/bin/env bash
# Script de Nautilus para procesar videos (capturas de frames) e imágenes (pixelize).
# Aparece en click derecho → Scripts dentro de Nautilus.
#
# Nautilus pasa los archivos seleccionados en $NAUTILUS_SCRIPT_SELECTED_FILE_PATHS,
# uno por línea. Soporta selección múltiple.

export PATH="/home/linuxbrew/.linuxbrew/bin:/home/tcabrera/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

CAPTURE_SCRIPT="$HOME/scripts/video_capture.py"
PIXELIZE_SCRIPT="$HOME/scripts/pixelize.py"
PIXELIZE_PYTHON="/home/tcabrera/.local/share/pipx/venvs/deface/bin/python3"

VIDEO_EXTS="mp4|mkv|avi|mov|webm|m4v|flv|wmv"
IMAGE_EXTS="jpg|jpeg|png|webp"

# ── Leer archivos seleccionados ──────────────────────────────────────────────
# Nautilus separa con \n; convertimos a array
mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    zenity --error --text="No se recibieron archivos." --title="Capturas"
    exit 1
fi

# ── Detectar tipo dominante (video o imagen) ─────────────────────────────────
# Si la selección mezcla tipos, usamos el primero para decidir el flujo
first="${files[0]}"
ext="${first##*.}"
ext="${ext,,}"  # lowercase

if echo "$ext" | grep -qE "^($VIDEO_EXTS)$"; then
    tipo="video"
elif echo "$ext" | grep -qE "^($IMAGE_EXTS)$"; then
    tipo="imagen"
else
    zenity --error --text="Tipo de archivo no soportado: .$ext" --title="Capturas"
    exit 1
fi

# ── Elegir modo con zenity ───────────────────────────────────────────────────
# zenity --list devuelve el valor de la columna seleccionada
if [ "$tipo" = "video" ]; then
    modo=$(zenity --list \
        --title="Procesar video" \
        --text="Elegí el modo de captura para ${#files[@]} archivo(s):" \
        --radiolist \
        --column="" --column="Modo" --column="Descripción" \
        --print-column=2 \
        TRUE  "medium" "Movimiento significativo (4 FPS) — recomendado" \
        FALSE "full"   "Todos los frames (FPS real del video)" \
        FALSE "low"    "Solo cambios grandes (2 FPS)" \
        --width=560 --height=400)
else
    modo=$(zenity --list \
        --title="Pixelizar imagen" \
        --text="Elegí el perfil para ${#files[@]} archivo(s):" \
        --radiolist \
        --column="" --column="Modo" --column="Descripción" \
        --print-column=2 \
        TRUE  "quick" "Variantes esenciales — rápido" \
        FALSE "full"  "Todas las variantes de anonimización" \
        --width=560 --height=360)
fi

# Si el usuario cancela el diálogo, salir silenciosamente
[ -z "$modo" ] && exit 0

# ── Procesar cada archivo ────────────────────────────────────────────────────
# Usamos zenity --progress para mostrar avance por archivo
(
    total=${#files[@]}
    i=0
    for file in "${files[@]}"; do
        i=$((i + 1))
        name=$(basename "$file")
        dir=$(dirname "$file")
        stem="${name%.*}"
        pct=$(( i * 100 / total ))

        echo "$pct"                        # zenity lee esto como porcentaje
        echo "# ($i/$total) $name"        # zenity muestra esto como texto

        if [ "$tipo" = "video" ]; then
            out_dir="$dir/${stem}_capturas_${modo}"

            # VLC recordings y cámaras IP → rotar 180°
            rotate_flag=""
            if echo "$name" | grep -qiE "^vlc-record|^rec_"; then
                rotate_flag="--rotate 180"
            fi

            python3 "$CAPTURE_SCRIPT" "$file" "$modo" $rotate_flag --output "$out_dir" 2>/dev/null

        else
            out_dir="$dir/$stem"
            "$PIXELIZE_PYTHON" "$PIXELIZE_SCRIPT" "$file" \
                --profile "$modo" --output-dir "$out_dir" 2>/dev/null

            # Marcar como procesado para que pixelize-inbox.sh no lo reprocese
            [ -d "$out_dir" ] && touch "$out_dir/.pixelize_done"
        fi
    done

    echo "100"
    echo "# Listo"
) | zenity --progress \
    --title="Procesando..." \
    --text="Iniciando..." \
    --percentage=0 \
    --auto-close \
    --width=380

# ── Notificación final ───────────────────────────────────────────────────────
pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null
notify-send "Capturas" "${#files[@]} archivo(s) procesado(s) en modo $modo" \
    --icon=emblem-photos
