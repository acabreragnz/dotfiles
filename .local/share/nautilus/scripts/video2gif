#!/usr/bin/env bash
# Convierte un tramo de video a GIF usando gifski (via ~/scripts/video2gif.py).
# Pide config con zenity: start, duration, fps, width, quality.

export PATH="/home/linuxbrew/.linuxbrew/bin:/home/tcabrera/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

SCRIPT="$HOME/scripts/video2gif.py"
PYTHON="/home/tcabrera/.local/share/pipx/venvs/deface/bin/python3"
VIDEO_EXTS="mp4|mov|mkv|webm|avi|m4v"

mapfile -t _raw <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${_raw[@]}"; do [[ -n "$f" ]] && files+=("$f"); done

if [ ${#files[@]} -eq 0 ]; then
    zenity --error --text="No se recibieron archivos." --title="Video → GIF"
    exit 1
fi

if [ ${#files[@]} -gt 1 ]; then
    zenity --error --text="Seleccioná un único video." --title="Video → GIF"
    exit 1
fi

src="${files[0]}"
ext="${src##*.}"
if ! echo "${ext,,}" | grep -qE "^($VIDEO_EXTS)$"; then
    zenity --error --text="Formato no soportado. Usá: ${VIDEO_EXTS//|/, }" --title="Video → GIF"
    exit 1
fi

# Metadata del video (para mostrar en el form)
duration_total=$(ffprobe -v error -show_entries format=duration -of default=nw=1:nk=1 "$src" 2>/dev/null | awk '{printf "%.1f", $1}')
dims=$(ffprobe -v error -select_streams v:0 -show_entries stream=width,height -of csv=p=0:s=x "$src" 2>/dev/null)
orig_w=$(echo "$dims" | cut -dx -f1)
orig_h=$(echo "$dims" | cut -dx -f2)

# Preset de calidad
preset=$(zenity --list \
    --title="Video → GIF — Preset" \
    --text="Duración del video: ${duration_total}s\n\nElegí preset inicial (después podés ajustar):" \
    --radiolist \
    --column="" --column="Preset" --column="Descripción" \
    --print-column=2 \
    TRUE  "balance" "15fps / 480px / q90 — recomendado" \
    FALSE "small"   "12fps / 360px / q80 — más liviano" \
    FALSE "hq"      "20fps / 640px / q95 — calidad máxima" \
    --width=520 --height=490)

[ -z "$preset" ] && exit 0

case "$preset" in
    small)   DEF_FPS=12; DEF_W=360; DEF_Q=80 ;;
    hq)      DEF_FPS=20; DEF_W=640; DEF_Q=95 ;;
    *)       DEF_FPS=15; DEF_W=480; DEF_Q=90 ;;
esac

# Form de configuración (vacío = aplica el default mostrado entre paréntesis)
values=$(zenity --forms \
    --title="Video → GIF" \
    --text="Archivo: $(basename "$src")\nDuración total: ${duration_total}s   ·   Original: ${orig_w}×${orig_h} px\n\nDejá Inicio y Fin vacíos = video entero. Ancho/Alto aceptan 'max' = original.\n" \
    --add-entry="Inicio — seg o HH:MM:SS (0)" \
    --add-entry="Fin — seg de duración, o HH:MM:SS (hasta el final)" \
    --add-entry="FPS (${DEF_FPS})" \
    --add-entry="Ancho px (${DEF_W}, 'max' = ${orig_w})" \
    --add-entry="Alto px para recortar (full, 'max' = ${orig_h})" \
    --add-combo="Recortar alto desde" --combo-values="center|top|bottom" \
    --add-entry="Calidad 1-100 (${DEF_Q})" \
    --add-combo="Pixelar caras" --combo-values="No|Sí (mosaic)" \
    --add-combo="Modelo (si pixelás)" --combo-values="SCRFD (balance · default)|RetinaFace-R34 (máx. precisión · lento)|CenterFace (rápido)" \
    --add-combo="Rellenar gaps (si pixelás)" --combo-values="Sí|No" \
    --separator="|" \
    --width=540 --height=696)

[ -z "$values" ] && exit 0

IFS='|' read -r START END FPS WIDTH CROP_HEIGHT CROP_Y QUALITY PIXELATE_CHOICE PIXELATE_MODEL PIXELATE_FILL <<< "$values"
PIXELATE=0
[[ "$PIXELATE_CHOICE" == "Sí (mosaic)" ]] && PIXELATE=1

START="${START:-0}"
FPS="${FPS:-$DEF_FPS}"
WIDTH="${WIDTH:-$DEF_W}"
QUALITY="${QUALITY:-$DEF_Q}"

# Ancho "max"/"full"/"-1" → ancho original del video
case "${WIDTH,,}" in
    max|full|-1|100%|original) WIDTH="$orig_w" ;;
esac

# Alto "max"/"full"/vacío → sin crop
case "${CROP_HEIGHT,,}" in
    ""|max|full|original|"${orig_h}") CROP_HEIGHT="" ;;
esac
CROP_Y="${CROP_Y:-center}"

parent=$(dirname "$src")

# Build args — si END tiene ':' es un timestamp → --to, si no es duración en seg → --duration
# El motor genera el nombre con rango temporal cuando corresponde; no pasamos -o.
args=(--start "$START" --fps "$FPS" --width "$WIDTH" --quality "$QUALITY")
if [[ -n "$END" ]]; then
    if [[ "$END" == *:* ]]; then
        args+=(--to "$END")
    else
        args+=(--duration "$END")
    fi
fi
if [[ -n "$CROP_HEIGHT" ]]; then
    args+=(--crop-height "$CROP_HEIGHT" --crop-y "$CROP_Y")
fi
if [[ "$PIXELATE" == "1" ]]; then
    args+=(--pixelate-faces)
    case "$PIXELATE_MODEL" in
        "CenterFace (rápido)") args+=(--pixelate-model centerface) ;;
        "RetinaFace-R34 (máx. precisión · lento)") args+=(--pixelate-model retinaface) ;;
        *) args+=(--pixelate-model scrfd) ;;
    esac
    [[ "$PIXELATE_FILL" == "No" ]] && args+=(--no-pixelate-fill-gaps)
fi

LOG=/tmp/video2gif.log
: > "$LOG"

(
    echo "10"
    echo "# Extrayendo frames..."
    "$PYTHON" "$SCRIPT" "$src" "${args[@]}" >>"$LOG" 2>&1 &
    PID=$!
    while kill -0 "$PID" 2>/dev/null; do
        if grep -q "Empaquetando" "$LOG"; then
            echo "85"
            echo "# Empaquetando GIF con gifski..."
        elif grep -q "Pixelando caras" "$LOG"; then
            last=$(grep -oE "[0-9]+/[0-9]+ frames" "$LOG" | tail -1)
            echo "50"
            echo "# Pixelando caras... ${last}"
        fi
        sleep 0.5
    done
    wait "$PID"
    rc=$?
    echo "100"
    if [[ $rc -eq 0 ]]; then
        echo "# Listo"
    else
        echo "# Error (ver $LOG)"
    fi
    exit $rc
) | zenity --progress \
    --title="Generando GIF..." \
    --text="Iniciando..." \
    --percentage=0 --auto-close --width=400

EXIT=${PIPESTATUS[0]}

pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null

# Motor imprime `✓ /abs/path  (XXX KB)` al final
out=$(grep -oE '^✓ /[^ ]+' "$LOG" | tail -1 | sed 's/^✓ //')

if [[ $EXIT -ne 0 || -z "$out" || ! -f "$out" ]]; then
    err=$(tail -5 "$LOG")
    zenity --error --title="Video → GIF — falló" --text="$err" --width=500
    exit 1
fi

size_kb=$(( $(stat -c%s "$out") / 1024 ))
action=$(notify-send --wait --action="open=Abrir carpeta" \
    "GIF listo" "$(basename "$out") — ${size_kb} KB" --icon=emblem-photos)
[[ "$action" == "open" ]] && nautilus "$parent" 2>/dev/null &
