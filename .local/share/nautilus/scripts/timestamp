#!/usr/bin/env bash
# Quema la fecha (mtime) en imágenes y/o videos seleccionados en Nautilus.
# Acepta archivos individuales (imágenes o videos) o un directorio.

export PATH="/home/linuxbrew/.linuxbrew/bin:/home/tcabrera/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

IMG_SCRIPT="$HOME/scripts/image_label.py"
VID_SCRIPT="$HOME/scripts/video_label.py"

IMAGE_EXTS="jpg|jpeg|png|webp|bmp|tiff|tif"
VIDEO_EXTS="mp4|mkv|avi|mov|webm|m4v|flv|wmv|gif"
ALL_EXTS="${IMAGE_EXTS}|${VIDEO_EXTS}"

mapfile -t _raw <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${_raw[@]}"; do [[ -n "$f" ]] && files+=("$f"); done

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    zenity --error --text="No files received." --title="Timestamp"
    exit 1
fi

get_unique_dir() {
    local base="$1"
    local dir="$base"
    local n=2
    while [[ -d "$dir" ]]; do dir="${base}_${n}"; n=$((n+1)); done
    echo "$dir"
}

# ── Position selection ────────────────────────────────────────────────────────
position=$(zenity --list \
    --title="Timestamp — position" \
    --text="Where to put the date? (pick one or more)" \
    --checklist \
    --column="" --column="Position" \
    --print-column=2 \
    --separator="," \
    TRUE  "right" \
    FALSE "left" \
    FALSE "center" \
    --width=480 --height=360)

[ -z "$position" ] && exit 0

# ── Directory mode ────────────────────────────────────────────────────────────
if [ -d "${files[0]}" ]; then
    dir="${files[0]}"
    mapfile -t items < <(find "$dir" -maxdepth 1 -type f | grep -iE "\.(${ALL_EXTS})$" | sort)

    if [ ${#items[@]} -eq 0 ]; then
        zenity --error --text="No images or videos found in the directory." --title="Timestamp"
        exit 1
    fi

    outdir=$(get_unique_dir "$(dirname "$dir")/$(basename "$dir")_labeled")
    mkdir -p "$outdir"

    WORKER_PID=""
    (
        total=${#items[@]}
        i=0
        for item in "${items[@]}"; do
            i=$((i + 1))
            name=$(basename "$item")
            ext="${name##*.}"
            pct=$(( i * 100 / total ))
            echo "$pct"
            echo "# ($i/$total) $name"
            if echo "${ext,,}" | grep -qE "^($IMAGE_EXTS)$"; then
                python3 "$IMG_SCRIPT" "$item" --position "$position" --output-dir "$outdir" >/dev/null 2>>/tmp/timestamp.log &
            else
                stem="${name%.*}"
                out_ext="mp4"; [[ "${ext,,}" == "gif" ]] && out_ext="gif"
                python3 "$VID_SCRIPT" "$item" --position "$position" --output "$outdir/${stem}_labeled.${out_ext}" >/dev/null 2>>/tmp/timestamp.log &
            fi
            WORKER_PID=$!
            wait $WORKER_PID
        done
        echo "100"
        echo "# Done"
    ) | zenity --progress --title="Applying timestamp..." --text="Starting..." \
        --percentage=0 --auto-close --width=380

    EXIT_CODE=${PIPESTATUS[1]}
    [[ $EXIT_CODE -ne 0 && -n "$WORKER_PID" ]] && kill "$WORKER_PID" 2>/dev/null && exit 0

    pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null
    action=$(notify-send --wait --action="open=Open folder" \
        "Timestamp done" "${#items[@]} file(s) → $(basename "$outdir")" --icon=emblem-photos)
    [[ "$action" == "open" ]] && nautilus "$outdir" 2>/dev/null &
    exit 0
fi

# ── Individual files mode ─────────────────────────────────────────────────────
ext="${files[0]##*.}"
if ! echo "${ext,,}" | grep -qE "^($ALL_EXTS)$"; then
    zenity --error --text="Unsupported format. Use images, videos or a directory." --title="Timestamp"
    exit 1
fi

single_mode=0
[ ${#files[@]} -eq 1 ] && single_mode=1

declare -a output_dirs=()
if [[ $single_mode -eq 0 ]]; then
    for file in "${files[@]}"; do
        parent=$(dirname "$file")
        stem=$(basename "${file%.*}")
        output_dirs+=("$(get_unique_dir "$parent/${stem}_labeled")")
    done
fi

WORKER_PID=""
(
    total=${#files[@]}
    i=0
    for file in "${files[@]}"; do
        i=$((i + 1))
        name=$(basename "$file")
        stem="${name%.*}"
        ext="${name##*.}"
        parent=$(dirname "$file")
        pct=$(( i * 100 / total ))
        echo "$pct"
        echo "# ($i/$total) $name"
        if [[ $single_mode -eq 1 ]]; then
            outdir="$parent"
        else
            outdir="${output_dirs[$((i-1))]}"
            mkdir -p "$outdir"
        fi
        if echo "${ext,,}" | grep -qE "^($IMAGE_EXTS)$"; then
            python3 "$IMG_SCRIPT" "$file" --position "$position" --output-dir "$outdir" >/dev/null 2>>/tmp/timestamp.log &
        else
            out_ext="mp4"; [[ "${ext,,}" == "gif" ]] && out_ext="gif"
            python3 "$VID_SCRIPT" "$file" --position "$position" --output "$outdir/${stem}_labeled.${out_ext}" >/dev/null 2>>/tmp/timestamp.log &
        fi
        WORKER_PID=$!
        wait $WORKER_PID
    done
    echo "100"
    echo "# Done"
) | zenity --progress --title="Applying timestamp..." --text="Starting..." \
    --percentage=0 --auto-close --width=380

EXIT_CODE=${PIPESTATUS[1]}
[[ $EXIT_CODE -ne 0 && -n "$WORKER_PID" ]] && kill "$WORKER_PID" 2>/dev/null && exit 0

pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null

if [[ $single_mode -eq 1 ]]; then
    only="${files[0]}"
    stem=$(basename "${only%.*}")
    ext="${only##*.}"
    parent=$(dirname "$only")
    if echo "${ext,,}" | grep -qE "^($IMAGE_EXTS)$"; then
        out="$parent/${stem}_labeled.${ext}"
    else
        out_ext="mp4"; [[ "${ext,,}" == "gif" ]] && out_ext="gif"
        out="$parent/${stem}_labeled.${out_ext}"
    fi
    action=$(notify-send --wait --action="open=Open folder" \
        "Timestamp done" "$(basename "$out")" --icon=emblem-photos)
    [[ "$action" == "open" ]] && nautilus "$parent" 2>/dev/null &
else
    action=$(notify-send --wait --action="open=Open folder" \
        "Timestamp done" "${#files[@]} file(s) → $(basename "${output_dirs[-1]}")" --icon=emblem-photos)
    [[ "$action" == "open" ]] && nautilus "${output_dirs[-1]}" 2>/dev/null &
fi
