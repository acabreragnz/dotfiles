#!/usr/bin/env bash
# Quema la fecha (mtime) en imágenes y/o videos seleccionados en Nautilus.
# Acepta archivos individuales (imágenes o videos) o un directorio.

export PATH="/home/linuxbrew/.linuxbrew/bin:/home/tcabrera/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

IMG_SCRIPT="$HOME/scripts/image_label.py"
VID_SCRIPT="$HOME/scripts/video_label.py"

IMAGE_EXTS="jpg|jpeg|png|webp|bmp|tiff|tif"
VIDEO_EXTS="mp4|mkv|avi|mov|webm|m4v|flv|wmv"
ALL_EXTS="${IMAGE_EXTS}|${VIDEO_EXTS}"

mapfile -t _raw <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${_raw[@]}"; do [[ -n "$f" ]] && files+=("$f"); done

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    zenity --error --text="No se recibieron archivos." --title="Timestamp"
    exit 1
fi

get_unique_dir() {
    local base="$1"
    local dir="$base"
    local n=2
    while [[ -d "$dir" ]]; do dir="${base}_${n}"; n=$((n+1)); done
    echo "$dir"
}

# ── Selección de posición ────────────────────────────────────────────────────
pos_sel=$(zenity --list \
    --title="Timestamp — posición" \
    --text="¿Dónde poner la fecha? (podés elegir varias)" \
    --checklist \
    --column="" --column="Posición" \
    --print-column=2 \
    --separator="," \
    TRUE  "derecha" \
    FALSE "izquierda" \
    FALSE "centro" \
    --width=480 --height=360)

[ -z "$pos_sel" ] && exit 0

position=$(echo "$pos_sel" \
    | sed 's/derecha/right/g; s/izquierda/left/g; s/centro/center/g')

# ── Modo directorio ───────────────────────────────────────────────────────────
if [ -d "${files[0]}" ]; then
    dir="${files[0]}"
    mapfile -t items < <(find "$dir" -maxdepth 1 -type f | grep -iE "\.(${ALL_EXTS})$" | sort)

    if [ ${#items[@]} -eq 0 ]; then
        zenity --error --text="No se encontraron imágenes ni videos en el directorio." --title="Timestamp"
        exit 1
    fi

    outdir=$(get_unique_dir "$(dirname "$dir")/$(basename "$dir")_labeled")
    mkdir -p "$outdir"

    WORKER_PID=""
    (
        total=${#items[@]}
        i=0
        for item in "${items[@]}"; do
            i=$((i + 1))
            name=$(basename "$item")
            ext="${name##*.}"
            pct=$(( i * 100 / total ))
            echo "$pct"
            echo "# ($i/$total) $name"
            if echo "${ext,,}" | grep -qE "^($IMAGE_EXTS)$"; then
                python3 "$IMG_SCRIPT" "$item" --position "$position" --output-dir "$outdir" >/dev/null 2>>/tmp/timestamp.log &
            else
                stem="${name%.*}"
                python3 "$VID_SCRIPT" "$item" --position "$position" --output "$outdir/${stem}_labeled.mp4" >/dev/null 2>>/tmp/timestamp.log &
            fi
            WORKER_PID=$!
            wait $WORKER_PID
        done
        echo "100"
        echo "# Listo"
    ) | zenity --progress --title="Aplicando timestamp..." --text="Iniciando..." \
        --percentage=0 --auto-close --width=380

    EXIT_CODE=${PIPESTATUS[1]}
    [[ $EXIT_CODE -ne 0 && -n "$WORKER_PID" ]] && kill "$WORKER_PID" 2>/dev/null && exit 0

    pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null
    action=$(notify-send --wait --action="open=Abrir carpeta" \
        "Timestamp listo" "${#items[@]} archivo(s) → $(basename "$outdir")" --icon=emblem-photos)
    [[ "$action" == "open" ]] && nautilus "$outdir" 2>/dev/null &
    exit 0
fi

# ── Modo archivos individuales ────────────────────────────────────────────────
ext="${files[0]##*.}"
if ! echo "${ext,,}" | grep -qE "^($ALL_EXTS)$"; then
    zenity --error --text="Formato no soportado. Usá imágenes, videos o un directorio." --title="Timestamp"
    exit 1
fi

declare -a output_dirs=()
for file in "${files[@]}"; do
    parent=$(dirname "$file")
    stem=$(basename "${file%.*}")
    output_dirs+=("$(get_unique_dir "$parent/${stem}_labeled")")
done

WORKER_PID=""
(
    total=${#files[@]}
    i=0
    for file in "${files[@]}"; do
        i=$((i + 1))
        name=$(basename "$file")
        stem="${name%.*}"
        ext="${name##*.}"
        outdir="${output_dirs[$((i-1))]}"
        mkdir -p "$outdir"
        pct=$(( i * 100 / total ))
        echo "$pct"
        echo "# ($i/$total) $name"
        if echo "${ext,,}" | grep -qE "^($IMAGE_EXTS)$"; then
            python3 "$IMG_SCRIPT" "$file" --position "$position" --output-dir "$outdir" >/dev/null 2>>/tmp/timestamp.log &
        else
            python3 "$VID_SCRIPT" "$file" --position "$position" --output "$outdir/${stem}_labeled.mp4" >/dev/null 2>>/tmp/timestamp.log &
        fi
        WORKER_PID=$!
        wait $WORKER_PID
    done
    echo "100"
    echo "# Listo"
) | zenity --progress --title="Aplicando timestamp..." --text="Iniciando..." \
    --percentage=0 --auto-close --width=380

EXIT_CODE=${PIPESTATUS[1]}
[[ $EXIT_CODE -ne 0 && -n "$WORKER_PID" ]] && kill "$WORKER_PID" 2>/dev/null && exit 0

pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null

action=$(notify-send --wait --action="open=Abrir carpeta" \
    "Timestamp listo" "${#files[@]} archivo(s) → $(basename "${output_dirs[-1]}")" --icon=emblem-photos)
[[ "$action" == "open" ]] && nautilus "${output_dirs[-1]}" 2>/dev/null &
