#!/usr/bin/env bash
# Extrae frames de videos seleccionados en Nautilus.

export PATH="/home/linuxbrew/.linuxbrew/bin:/home/tcabrera/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

SCRIPT="$HOME/scripts/video_capture.py"
VIDEO_EXTS="mp4|mkv|avi|mov|webm|m4v|flv|wmv"

mapfile -t _raw <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${_raw[@]}"; do [[ -n "$f" ]] && files+=("$f"); done

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    zenity --error --text="No files received." --title="Extract frames"
    exit 1
fi

ext="${files[0]##*.}"
if ! echo "${ext,,}" | grep -qE "^($VIDEO_EXTS)$"; then
    zenity --error --text="This script only handles videos." --title="Extract frames"
    exit 1
fi

# ── Mode selection (radiolist) ────────────────────────────────────────────────
mode=$(zenity --list \
    --title="Extract frames" \
    --text="Pick mode for ${#files[@]} file(s):" \
    --radiolist \
    --column="" --column="Mode" --column="Description" \
    --print-column=2 \
    TRUE  "smart"  "Auto-detect active zones (MOG2) + full FPS inside — recommended" \
    FALSE "medium" "Significant motion (4 FPS)" \
    FALSE "full"   "All frames (video's real FPS)" \
    FALSE "low"    "Only big changes (2 FPS)" \
    --width=640 --height=560)

[ -z "$mode" ] && exit 0

# ── Date overlay position ─────────────────────────────────────────────────────
date_position=$(zenity --list \
    --title="Extract frames — date overlay" \
    --text="Date overlay position:" \
    --checklist \
    --column="" --column="Position" \
    --print-column=2 \
    --separator="," \
    FALSE "none" \
    TRUE  "right" \
    FALSE "left" \
    FALSE "center" \
    --width=400 --height=490)

[ $? -ne 0 ] && exit 0

date_flag=""
if [[ -z "$date_position" || "$date_position" == "none" || "$date_position" == *"none"* ]]; then
    date_flag="--no-date"
else
    date_flag="--date-position ${date_position//,none/}"
    date_flag="${date_flag//none,/}"
fi

# ── Pixelize option (separate checkbox) ───────────────────────────────────────
pixelize_flag=""
zenity --question \
    --title="Extract frames — pixelize" \
    --text="Anonymize faces in the extracted frames?" \
    --ok-label="Yes" --cancel-label="No" --default-cancel 2>/dev/null \
    && pixelize_flag="--pixelize"

# ── Output size preset ────────────────────────────────────────────────────────
preset=$(zenity --list \
    --title="Extract frames — output size" \
    --text="Output size preset:" \
    --radiolist \
    --column="" --column="Preset" --column="Details" \
    --print-column=2 \
    TRUE  "standard"  "Quality 85%, up to 1920px — recommended" \
    FALSE "compact"   "Quality 75%, up to 1280px — ~3× smaller" \
    FALSE "miniature" "Quality 65%, up to 854px  — ~8× smaller" \
    --width=640 --height=490)

[ -z "$preset" ] && exit 0

case "$preset" in
    standard)  quality=85; max_width=1920 ;;
    compact)   quality=75; max_width=1280 ;;
    miniature) quality=65; max_width=854  ;;
    *)         quality=85; max_width=1920 ;;
esac

# ── Warning for full mode ─────────────────────────────────────────────────────
if [[ "$mode" == "full" ]]; then
    total_frames=0
    for file in "${files[@]}"; do
        fps_raw=$(ffprobe -v quiet -select_streams v:0 \
            -show_entries stream=r_frame_rate \
            -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null)
        dur=$(ffprobe -v quiet -select_streams v:0 \
            -show_entries stream=duration \
            -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null | awk '{print int($1+0.5)}')
        fps=$(echo "$fps_raw" | awk -F/ '{if($2>0) printf "%d", $1/$2; else print 0}')
        total_frames=$(( total_frames + fps * dur ))
    done
    if [[ $total_frames -gt 500 ]]; then
        zenity --question \
            --title="Extract frames — full mode" \
            --text="Full mode will generate approximately <b>$total_frames frames</b>.\nContinue?" \
            --ok-label="Continue" --cancel-label="Cancel" 2>/dev/null || exit 0
    fi
fi

# ── Info for smart mode ───────────────────────────────────────────────────────
if [[ "$mode" == "smart" ]]; then
    total_dur=0
    for file in "${files[@]}"; do
        dur=$(ffprobe -v quiet -select_streams v:0 \
            -show_entries stream=duration \
            -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null | awk '{print int($1+0.5)}')
        total_dur=$(( total_dur + dur ))
    done
    est_min=$(( total_dur / 60 / 5 ))  # rough: ~5x realtime for scan
    [[ $est_min -lt 1 ]] && est_min=1
    zenity --question \
        --title="Extract frames — smart mode" \
        --text="Smart mode: first scans the full video with MOG2 to find active zones, then extracts all frames inside those zones.\n\nThe scan output does NOT appear until it finishes (~${est_min} min for ${total_dur}s of video).\n\nContinue?" \
        --ok-label="Continue" --cancel-label="Cancel" 2>/dev/null || exit 0
fi

# ── Output dirs ───────────────────────────────────────────────────────────────
declare -a output_dirs=()
for file in "${files[@]}"; do
    dir=$(dirname "$file")
    stem=$(basename "${file%.*}")
    output_dirs+=("$dir/${stem}_frames_${mode}_${preset}")
done

PID_FILE=$(mktemp)

(
    total=${#files[@]}
    i=0
    for file in "${files[@]}"; do
        i=$((i + 1))
        name=$(basename "$file")
        pct=$(( i * 100 / total ))
        echo "$pct"
        echo "# ($i/$total) $name"
        python3 "$SCRIPT" "$file" "$mode" $pixelize_flag $date_flag \
            --quality "$quality" --max-width "$max_width" \
            --output "${output_dirs[$((i-1))]}" >/dev/null 2>/dev/null &
        echo $! > "$PID_FILE"
        wait
    done
    echo "100"
    echo "# Done"
) | zenity --progress \
    --title="Extracting frames..." \
    --text="Starting..." \
    --percentage=0 --auto-close --width=380

EXIT_CODE=${PIPESTATUS[1]}
if [[ $EXIT_CODE -ne 0 ]]; then
    WPID=$(cat "$PID_FILE" 2>/dev/null)
    [[ -n "$WPID" ]] && kill "$WPID" 2>/dev/null
    rm -f "$PID_FILE"; exit 0
fi
rm -f "$PID_FILE"

pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null

failed=0
for d in "${output_dirs[@]}"; do [[ ! -d "$d" ]] && failed=$((failed + 1)); done
ok=$(( ${#files[@]} - failed ))

if [[ $failed -gt 0 && $ok -eq 0 ]]; then
    notify-send "Extract frames — error" "No frames generated for any video" --icon=dialog-error
elif [[ $failed -gt 0 ]]; then
    action=$(notify-send --wait --action="open=Open folder" \
        "Frames extracted (with errors)" "$ok processed, $failed failed" --icon=emblem-photos)
    [[ "$action" == "open" ]] && nautilus "${output_dirs[-1]}" 2>/dev/null &
else
    action=$(notify-send --wait --action="open=Open folder" \
        "Frames extracted" "$ok file(s) in $mode mode" --icon=emblem-photos)
    [[ "$action" == "open" ]] && nautilus "${output_dirs[-1]}" 2>/dev/null &
fi
