#!/usr/bin/env bash
# Quema la fecha (mtime) en videos seleccionados en Nautilus.

export PATH="/home/linuxbrew/.linuxbrew/bin:/home/tcabrera/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

SCRIPT="$HOME/scripts/video_label.py"

VIDEO_EXTS="mp4|mkv|avi|mov|webm|m4v|flv|wmv"

mapfile -t _raw <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${_raw[@]}"; do [[ -n "$f" ]] && files+=("$f"); done

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    zenity --error --text="No se recibieron archivos." --title="Fecha en video"
    exit 1
fi

ext="${files[0]##*.}"
if ! echo "${ext,,}" | grep -qE "^($VIDEO_EXTS)$"; then
    zenity --error --text="Este script es solo para videos." --title="Fecha en video"
    exit 1
fi

declare -a output_files=()
for file in "${files[@]}"; do
    dir=$(dirname "$file")
    stem=$(basename "${file%.*}")
    output_files+=("$dir/${stem}_labeled.mp4")
done

WORKER_PID=""

(
    total=${#files[@]}
    i=0
    for file in "${files[@]}"; do
        i=$((i + 1))
        name=$(basename "$file")
        pct=$(( i * 100 / total ))
        echo "$pct"
        echo "# ($i/$total) $name"

        python3 "$SCRIPT" "$file" >/dev/null 2>>/tmp/fecha-video.log &
        WORKER_PID=$!
        wait $WORKER_PID
    done
    echo "100"
    echo "# Listo"
) | zenity --progress \
    --title="Quemando fecha en video..." \
    --text="Iniciando..." \
    --percentage=0 --auto-close --width=380

EXIT_CODE=${PIPESTATUS[1]}
if [[ $EXIT_CODE -ne 0 && -n "$WORKER_PID" ]]; then
    kill "$WORKER_PID" 2>/dev/null; exit 0
fi

pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null

failed=0
for f in "${output_files[@]}"; do [[ ! -f "$f" ]] && failed=$((failed + 1)); done
ok=$(( ${#files[@]} - failed ))

if [[ $failed -gt 0 && $ok -eq 0 ]]; then
    notify-send "Fecha en video — error" "No se procesó ningún video" --icon=dialog-error
elif [[ $failed -gt 0 ]]; then
    action=$(notify-send --wait --action="open=Abrir carpeta" \
        "Fecha en video (con errores)" "$ok procesado(s), $failed fallido(s)" --icon=emblem-videos)
    [[ "$action" == "open" ]] && nautilus "$(dirname "${files[0]}")" 2>/dev/null &
else
    action=$(notify-send --wait --action="open=Abrir carpeta" \
        "Fecha en video" "$ok video(s) procesado(s)" --icon=emblem-videos)
    [[ "$action" == "open" ]] && nautilus "$(dirname "${files[0]}")" 2>/dev/null &
fi
