#!/usr/bin/env bash
# Rota un video seleccionado en Nautilus usando ffmpeg (re-encoding).

export PATH="/home/linuxbrew/.linuxbrew/bin:/home/tcabrera/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

VIDEO_EXTS="mp4|mkv|avi|mov|webm|m4v|flv|wmv"

mapfile -t _raw <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${_raw[@]}"; do [[ -n "$f" ]] && files+=("$f"); done

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    zenity --error --text="No files received." --title="Rotate video"
    exit 1
fi

ext="${files[0]##*.}"
if ! echo "${ext,,}" | grep -qE "^($VIDEO_EXTS)$"; then
    zenity --error --text="This script only handles videos." --title="Rotate video"
    exit 1
fi

get_unique_dir() {
    local base="$1"
    local dir="$base"
    local n=2
    while [[ -d "$dir" ]]; do dir="${base}_${n}"; n=$((n+1)); done
    echo "$dir"
}

angle=$(zenity --list \
    --title="Rotate video" \
    --text="Pick rotation for ${#files[@]} video(s):" \
    --radiolist \
    --column="" --column="Angle" --column="Description" \
    --print-column=2 \
    TRUE  "180"  "180° — recorded upside down (most common)" \
    FALSE "90"   "90° — clockwise" \
    FALSE "270"  "270° — counter-clockwise" \
    --width=480 --height=300)

[ -z "$angle" ] && exit 0

case "$angle" in
    90)  vf="transpose=1" ;;
    180) vf="hflip,vflip" ;;
    270) vf="transpose=2" ;;
esac

single_mode=0
[ ${#files[@]} -eq 1 ] && single_mode=1

declare -a output_dirs=()
declare -a output_files=()
for file in "${files[@]}"; do
    dir=$(dirname "$file")
    stem=$(basename "${file%.*}")
    if [[ $single_mode -eq 1 ]]; then
        out="$dir/${stem}_rotated_${angle}.mp4"
        n=2
        while [[ -f "$out" ]]; do out="$dir/${stem}_rotated_${angle}_${n}.mp4"; n=$((n+1)); done
        output_dirs+=("$dir")
        output_files+=("$out")
    else
        outdir=$(get_unique_dir "$dir/${stem}_rotated_${angle}")
        output_dirs+=("$outdir")
        output_files+=("$outdir/${stem}_rotated_${angle}.mp4")
    fi
done

PID_FILE=$(mktemp)

(
    total=${#files[@]}
    i=0
    for file in "${files[@]}"; do
        i=$((i + 1))
        name=$(basename "$file")
        outdir="${output_dirs[$((i-1))]}"
        out="${output_files[$((i-1))]}"
        pct=$(( i * 100 / total ))
        echo "$pct"
        echo "# ($i/$total) $name"

        codec=$(ffprobe -v quiet -select_streams v:0 \
            -show_entries stream=codec_name \
            -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null)
        case "$codec" in
            mjpeg) vcodec="mjpeg";      quality_flags=(-q:v 2) ;              pix_fmt=() ;;
            hevc)  vcodec="libx265";    quality_flags=(-crf 15) ;             pix_fmt=(-pix_fmt yuv420p) ;;
            vp9)   vcodec="libvpx-vp9"; quality_flags=(-crf 18 -b:v 0) ;     pix_fmt=(-pix_fmt yuv420p) ;;
            *)     vcodec="libx264";    quality_flags=(-crf 15 -preset slow) ; pix_fmt=(-pix_fmt yuv420p) ;;
        esac

        [[ $single_mode -eq 0 ]] && mkdir -p "$outdir"
        ffmpeg -y -i "$file" -vf "$vf" -c:v "$vcodec" "${quality_flags[@]}" "${pix_fmt[@]}" \
               -c:a copy -map_metadata 0 -metadata:s:v:0 rotate=0 "$out" 2>/dev/null &
        echo $! > "$PID_FILE"
        wait
        touch -r "$file" "$out" 2>/dev/null
    done
    echo "100"
    echo "# Done"
) | zenity --progress \
    --title="Rotating video..." \
    --text="Starting..." \
    --percentage=0 --auto-close --width=380

EXIT_CODE=${PIPESTATUS[1]}
if [[ $EXIT_CODE -ne 0 ]]; then
    WPID=$(cat "$PID_FILE" 2>/dev/null)
    [[ -n "$WPID" ]] && kill "$WPID" 2>/dev/null
    rm -f "$PID_FILE"; exit 0
fi
rm -f "$PID_FILE"

pw-play /usr/share/sounds/freedesktop/stereo/message.oga 2>/dev/null

failed=0
for f in "${output_files[@]}"; do [[ ! -f "$f" ]] && failed=$((failed + 1)); done
ok=$(( ${#files[@]} - failed ))

if [[ $failed -gt 0 && $ok -eq 0 ]]; then
    notify-send "Rotate video — error" "Could not rotate any video" --icon=dialog-error
elif [[ $failed -gt 0 ]]; then
    action=$(notify-send --wait --action="open=Open folder" \
        "Video rotated (with errors)" "$ok rotated, $failed failed" --icon=emblem-videos)
    [[ "$action" == "open" ]] && nautilus "$(dirname "${output_files[0]}")" 2>/dev/null &
else
    action=$(notify-send --wait --action="open=Open folder" \
        "Video rotated" "$ok video(s) — ${angle}°" --icon=emblem-videos)
    [[ "$action" == "open" ]] && nautilus "$(dirname "${output_files[0]}")" 2>/dev/null &
fi
