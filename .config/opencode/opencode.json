{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "slack": {
      "type": "remote",
      "url": "https://mcp.slack.com/mcp",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--experimental-page-id-routing",
        "--experimentalScreencast"
      ],
      "enabled": true
    },
    "react-aria": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@react-aria/mcp@latest"
      ],
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "apify": {
      "type": "remote",
      "url": "https://mcp.apify.com/?tools=actors,docs,apify/instagram-profile-scraper",
      "enabled": true
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "untitledui": {
      "type": "remote",
      "url": "https://www.untitledui.com/react/api/mcp",
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "clickup": {
      "type": "remote",
      "url": "https://mcp.clickup.com/mcp",
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true
    }
  },
  "plugin": [
    "@warp-dot-dev/opencode-warp@0.1.5"
  ]
}
